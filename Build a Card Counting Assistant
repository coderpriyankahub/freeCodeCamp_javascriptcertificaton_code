let count = 0;

function cardCounter(card) {
  // 1. Card ke mutabik count change karna
  if (card >= 2 && card <= 6) {
    count++;
  } else if (card === 10 || card === "J" || card === "Q" || card === "K" || card === "A") {
    count--;
  }

  // 2. Jo rules aapne abhi bheje (Bet ya Hold return karna)
  if (count > 0) {
    return count + " Bet";
  } else {
    return count + " Hold";
  }
}
